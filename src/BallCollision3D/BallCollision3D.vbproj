<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.17763.0</TargetFramework>
    <RootNamespace>BallCollision3D</RootNamespace>
    <AssemblyName>BallCollision3D</AssemblyName>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>Off</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <UseWindowsForms>true</UseWindowsForms>
    <StartupObject>BallCollision3D.MainForm</StartupObject>
    <Platforms>AnyCPU;x64</Platforms>
    <UseWPF>True</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\framework\Microsoft.VisualBasic.Core\src\Core.vbproj" />
    <ProjectReference Include="..\framework\Data_science\Mathematica\Math\Math\Math.NET5.vbproj" />
    <ProjectReference Include="..\framework\gr\Microsoft.VisualBasic.Imaging\imaging.NET5.vbproj" />
    <ProjectReference Include="..\framework\gr\physics\physics-netcore5.vbproj" />
  </ItemGroup>

</Project>
